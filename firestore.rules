rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══ ACCESS LOGS ══
    // Cualquiera puede crear un log (al iniciar sesión).
    // Cualquiera puede leer y borrar (el Master valida en frontend).
    match /access_logs/{logId} {
      allow read, write: if true;
    }

    // ══ CLIENTES (registro de cuentas) ══
    match /clientes/{docId} {
      allow read, write: if true;
    }

    // ══ OBRAS y sub-colecciones (galería, tokens, notas) ══
    match /obras/{obraId} {
      allow read, write: if true;

      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    // ══ USERS (perfiles) ══
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
