rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si es el Master (Manel)
    function isMaster() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master'
      );
    }

    // Regla para Obras: Todos pueden leer, solo Master puede escribir
    match /obras/{obraId} {
      allow read: if true;
      allow write: if isMaster();
      
      // Regla para fotos dentro de la obra
      match /fotos/{fotoId} {
        allow read: if true;
        allow write: if isMaster();
        allow delete: if isMaster();
      }
      
      // Regla para notas semanales
      match /weekly_notes/{noteId} {
        allow read: if true;
        allow write: if isMaster();
      }
    }

    // Regla para Logs de Acceso: 
    // Cualquiera puede crear un log (al entrar), pero NADIE puede borrarlos ni editarlos
    match /access_logs/{logId} {
      allow create: if true;
      allow read: if isMaster();
      allow update, delete: if false; 
    }
    
    // Regla para Perfiles de Usuario (si usamos Firebase Auth en el futuro)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Solo se crean vía Admin/Cloud Functions
    }
  }
}
