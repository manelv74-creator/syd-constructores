rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de verificación de Rol
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isSignedIn() && getUserData().role == 'master';
    }

    function isObserver() {
      return isSignedIn() && getUserData().role == 'observer';
    }

    function isClientOf(obraId) {
      return isSignedIn() && getUserData().role == 'client' && getUserData().obra == obraId;
    }

    // Regla para Obras: Solo Master/Observer ven todo. Clientes solo SU obra.
    match /obras/{obraId} {
      allow read: if isMaster() || isObserver() || isClientOf(obraId);
      allow write: if isMaster();
      
      // Regla para fotos y notas dentro de la obra (heredan permiso)
      match /{allSubcollections=**} {
        allow read: if isMaster() || isObserver() || isClientOf(obraId);
        allow write: if isMaster();
      }
    }

    // Regla para Logs de Acceso: Master lee, cualquiera logueado escribe.
    match /access_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isMaster();
      allow update, delete: if false; 
    }
    
    // Regla para Perfiles de Usuario: Solo el propio usuario lee su perfil.
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn(); // Permitir creación inicial al registrarse
      allow update, delete: if isMaster();
    }
  }
}
